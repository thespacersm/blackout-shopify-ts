{% doc %}
  @prompt
    Un'intestazione con un effetto luminoso animato
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    position: relative;
    display: inline-block;
    text-shadow: 
      0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
    animation: ai-glow-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0%, 100% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
    }
    50% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity | times: 1.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 4.5 }}px {{ block.settings.glow_color }};
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_tag == 'h1' %}
    <h1 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
  {% elsif block.settings.heading_tag == 'h2' %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
  {% elsif block.settings.heading_tag == 'h3' %}
    <h3 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
  {% elsif block.settings.heading_tag == 'h4' %}
    <h4 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
  {% elsif block.settings.heading_tag == 'h5' %}
    <h5 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
  {% else %}
    <h6 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
  {% endif %}
</div>

{% schema %}
{
  "name": "Intestazione luminosa",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Testo intestazione",
      "default": "Benvenuti nel nostro negozio"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag HTML",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Stile testo"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Dimensione carattere",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Spessore carattere",
      "options": [
        { "value": "300", "label": "Leggero" },
        { "value": "400", "label": "Normale" },
        { "value": "500", "label": "Medio" },
        { "value": "600", "label": "Semi grassetto" },
        { "value": "700", "label": "Grassetto" },
        { "value": "800", "label": "Extra grassetto" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Allineamento",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Colore testo",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Effetto luminoso"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Colore bagliore",
      "default": "#48c8fd"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Intensità bagliore",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Velocità animazione",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "s",
      "default": 2
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Larghezza desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Spaziatura",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Intestazione luminosa"
    }
  ]
}
{% endschema %}
