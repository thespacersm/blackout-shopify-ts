{% doc %}
  @prompt
    Un'intestazione con un effetto luminoso animato
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px 0;
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: {{ block.settings.text_align }};
    color: {{ block.settings.text_color }};
    margin: 0;
    position: relative;
    display: inline-block;
    text-shadow: 
      0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
  }

  .ai-glow-heading__wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_align }};
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<ai-glow-heading-{{ ai_gen_id }} class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-glow-heading__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading_tag == 'h1' %}
      <h1 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
    {% elsif block.settings.heading_tag == 'h2' %}
      <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
    {% elsif block.settings.heading_tag == 'h3' %}
      <h3 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
    {% elsif block.settings.heading_tag == 'h4' %}
      <h4 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
    {% elsif block.settings.heading_tag == 'h5' %}
      <h5 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
    {% else %}
      <h6 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
    {% endif %}
  </div>
</ai-glow-heading-{{ ai_gen_id }}>

<script>
  (function() {
    class AiGlowHeading{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.headingElement = this.querySelector('.ai-glow-heading__text-{{ ai_gen_id }}');
        if (!this.headingElement) return;
      }
    }

    customElements.define('ai-glow-heading-{{ ai_gen_id }}', AiGlowHeading{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Intestazione luminosa",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Contenuto"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Testo intestazione",
      "default": "Intestazione luminosa"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Tag HTML",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Stile testo"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Dimensione carattere",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Peso carattere",
      "options": [
        {
          "value": "300",
          "label": "Leggero"
        },
        {
          "value": "400",
          "label": "Normale"
        },
        {
          "value": "500",
          "label": "Medio"
        },
        {
          "value": "600",
          "label": "Semi grassetto"
        },
        {
          "value": "700",
          "label": "Grassetto"
        },
        {
          "value": "800",
          "label": "Extra grassetto"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Allineamento",
      "options": [
        {
          "value": "left",
          "label": "Sinistra"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Destra"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Colore testo",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Effetto luminoso"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Colore bagliore",
      "default": "#48c8fd"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Intensità bagliore",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Larghezza desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Spaziatura verticale",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Intestazione luminosa"
    }
  ]
}
{% endschema %}
